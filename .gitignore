# (reports .md, FINDING_*.md files) IS versioned.

# T3MP3ST integration (separate repo, updated via git pull in t3mp3st/)
t3mp3st/

# Logs and daemons
*.log
auto-scanner/logs/
**/daemon-*.log

# Local databases and caches
auto-scanner/db/
*.sqlite
*.sqlite3
*.db
.cache/
**/.cache/

# Temporary files
*.tmp
*.swp
*~
.DS_Store
Thumbs.db

# Directories recreated automatically by scripts (empty)
legacy-vm-practice/vms/
legacy-vm-practice/network/

# ── OPTIONAL: raw recon dumps (uncomment to ignore them) ───────────
# These are regenerable recon output. Left versioned by default
# because they often serve as evidence for a finding. Uncomment if
# you prefer keeping the repo lightweight and regenerating them
# with bugbounty-hunter.sh.
#
# bugbounty/reports/*/recon/*.json
# bugbounty/reports/*/recon/wayback_raw.json
# bugbounty/reports/*/recon/*_urls.txt
# auto-scanner/threat-intel/
